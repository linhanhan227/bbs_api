<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - 交友社区管理后台</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: "Microsoft YaHei", -apple-system, sans-serif; background: #f0f2f5; color: #333; }
    .layout { display: flex; min-height: 100vh; }
    .sidebar { width: 200px; background: #001529; color: #fff; flex-shrink: 0; }
    .sidebar .logo { padding: 20px 16px; font-size: 17px; font-weight: bold; border-bottom: 1px solid #1f2d3d; }
    .sidebar nav a { display: block; padding: 13px 24px; color: rgba(255,255,255,.65); text-decoration: none; }
    .sidebar nav a:hover { color: #fff; }
    .sidebar nav a.active { color: #fff; background: #1890ff; }
    .main { flex: 1; display: flex; flex-direction: column; }
    .topbar { background: #fff; padding: 12px 24px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .content { padding: 24px; }
    .card { background: #fff; border-radius: 8px; padding: 20px; margin-bottom: 20px; box-shadow: 0 1px 2px rgba(0,0,0,.05); }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 11px 12px; text-align: left; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
    th { background: #fafafa; font-weight: 600; }
    .btn { display: inline-block; padding: 6px 14px; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; text-decoration: none; }
    .btn-primary { background: #1890ff; color: #fff; }
    .btn-danger { background: #ff4d4f; color: #fff; }
    .btn-warn { background: #faad14; color: #fff; }
    .btn-default { background: #fff; border: 1px solid #d9d9d9; color: #333; }
    .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; }
    .tag-green { background: #f6ffed; color: #52c41a; border: 1px solid #b7eb8f; }
    .tag-red { background: #fff1f0; color: #ff4d4f; border: 1px solid #ffa39e; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .stat-card { background: #fff; border-radius: 8px; padding: 20px; box-shadow: 0 1px 2px rgba(0,0,0,.05); }
    .stat-card .num { font-size: 28px; font-weight: bold; color: #1890ff; margin-top: 6px; }
    .pagination { margin-top: 16px; display: flex; gap: 8px; align-items: center; }
    .search-bar { margin-bottom: 16px; display: flex; gap: 8px; }
    .search-bar input { padding: 7px 12px; border: 1px solid #d9d9d9; border-radius: 4px; width: 240px; }
    form.inline { display: inline; }
    h2 { margin-bottom: 16px; font-size: 18px; }
  </style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="logo">💬 交友社区</div>
    <nav>
      <a href="/admin" class="<%= active === 'dashboard' ? 'active' : '' %>">📊 仪表盘</a>
      <a href="/admin/users" class="<%= active === 'users' ? 'active' : '' %>">👥 用户管理</a>
      <a href="/admin/posts" class="<%= active === 'posts' ? 'active' : '' %>">📝 动态管理</a>
      <a href="/admin/comments" class="<%= active === 'comments' ? 'active' : '' %>">💬 评论管理</a>
      <a href="/admin/reports" class="<%= active === 'reports' ? 'active' : '' %>">🚨 举报管理</a>
    </nav>
  </aside>
  <div class="main">
    <div class="topbar">
      <span><%= title %></span>
      <span>
        管理员：<strong><%= admin.nickname || admin.username %></strong>
        <form class="inline" method="post" action="/admin/logout" style="margin-left:12px">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-default" type="submit">退出登录</button>
        </form>
      </span>
    </div>
    <div class="content">
