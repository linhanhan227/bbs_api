<%- include('partials/header', { title: '用户管理', admin, active }) %>

<div class="card">
  <h2>用户管理（共 <%= total %> 人）</h2>
  <form class="search-bar" method="get" action="/admin/users">
    <input type="text" name="keyword" placeholder="搜索用户名 / 昵称" value="<%= keyword %>">
    <button class="btn btn-primary" type="submit">搜索</button>
    <% if (keyword) { %><a class="btn btn-default" href="/admin/users">清除</a><% } %>
  </form>
  <table>
    <thead>
      <tr>
        <th>ID</th><th>用户名</th><th>昵称</th><th>性别</th><th>年龄</th><th>城市</th><th>状态</th><th>注册时间</th><th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
      <tr>
        <td><%= u.id %></td>
        <td><%= u.username %></td>
        <td><%= u.nickname %></td>
        <td><%= u.gender === 'male' ? '男' : u.gender === 'female' ? '女' : '保密' %></td>
        <td><%= u.age || '-' %></td>
        <td><%= u.city || '-' %></td>
        <td>
          <% if (u.status === 'active') { %><span class="tag tag-green">正常</span>
          <% } else { %><span class="tag tag-red">已封禁</span><% } %>
        </td>
        <td><%= u.createdAt.toLocaleString('zh-CN') %></td>
        <td>
          <form class="inline" method="post" action="/admin/users/<%= u.id %>/toggle-ban">
            <button class="btn <%= u.status === 'active' ? 'btn-warn' : 'btn-primary' %>" type="submit">
              <%= u.status === 'active' ? '封禁' : '解封' %>
            </button>
          </form>
          <form class="inline" method="post" action="/admin/users/<%= u.id %>/delete"
                onsubmit="return confirm('确定删除用户 <%= u.username %> 及其全部内容？此操作不可恢复！')">
            <button class="btn btn-danger" type="submit">删除</button>
          </form>
        </td>
      </tr>
      <% }) %>
      <% if (!users.length) { %>
      <tr><td colspan="9" style="text-align:center;color:#999">暂无数据</td></tr>
      <% } %>
    </tbody>
  </table>
  <div class="pagination">
    <% if (page > 1) { %><a class="btn btn-default" href="?page=<%= page - 1 %>&keyword=<%= encodeURIComponent(keyword) %>">上一页</a><% } %>
    <span>第 <%= page %> / <%= totalPages %> 页</span>
    <% if (page < totalPages) { %><a class="btn btn-default" href="?page=<%= page + 1 %>&keyword=<%= encodeURIComponent(keyword) %>">下一页</a><% } %>
  </div>
</div>

<%- include('partials/footer') %>
