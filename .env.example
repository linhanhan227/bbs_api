# 运行环境: production 使用 MySQL, development/test 使用 SQLite
# 复制本文件为 .env 并按需修改

PORT=3000

# JWT 密钥（务必修改）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# 管理后台 session 密钥（务必修改）
SESSION_SECRET=change-me-too

# MySQL 配置（仅 production 使用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=friend_community
MYSQL_USER=root
MYSQL_PASSWORD=your-password

# SQLite 数据文件路径（development/test 使用）
SQLITE_STORAGE=./data/community.sqlite

# 默认管理员账号（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
